   5:ReactivePedal.cpp **** using namespace daisy;
   6:ReactivePedal.cpp **** 
   7:ReactivePedal.cpp **** // ============================================================
   8:ReactivePedal.cpp **** // Karplus–Strong 6-string Strummer (More Guitar-like)
   9:ReactivePedal.cpp **** // - 6 KS strings (delay-line plucked string model)
  10:ReactivePedal.cpp **** // - Strum scheduler with stagger
  11:ReactivePedal.cpp **** // - Simple "body" resonance comb
ARM GAS  /var/folders/6_/psd2b8g56p7696hhrr4ztjs00000gn/T//ccJilNki.s 			page 23


  12:ReactivePedal.cpp **** //
  13:ReactivePedal.cpp **** // Controls:
  14:ReactivePedal.cpp **** //   Knob1 = BPM (70..160)
  15:ReactivePedal.cpp **** //   Knob2 = Tone (bright -> darker)
  16:ReactivePedal.cpp **** //   Encoder = chord (0..3)
  17:ReactivePedal.cpp **** //   Button1 = start/stop (starts ON)
  18:ReactivePedal.cpp **** // ============================================================
  19:ReactivePedal.cpp **** 
  20:ReactivePedal.cpp **** DaisyPod hw;
  21:ReactivePedal.cpp **** static float sample_rate = 48000.0f;
  22:ReactivePedal.cpp **** 
  23:ReactivePedal.cpp **** static constexpr int   kNumStrings = 6;
  24:ReactivePedal.cpp **** static constexpr float kOutGain    = 0.35f; // earphone-safe-ish
  25:ReactivePedal.cpp **** 
  26:ReactivePedal.cpp **** // --------- Helpers ----------
  27:ReactivePedal.cpp **** static inline float clampf(float x, float lo, float hi)
  28:ReactivePedal.cpp **** {
  29:ReactivePedal.cpp ****     return (x < lo) ? lo : (x > hi ? hi : x);
  30:ReactivePedal.cpp **** }
  31:ReactivePedal.cpp **** 
  32:ReactivePedal.cpp **** static inline float mtof(float m)
  33:ReactivePedal.cpp **** {
  34:ReactivePedal.cpp ****     return 440.0f * powf(2.0f, (m - 69.0f) / 12.0f);
  35:ReactivePedal.cpp **** }
  36:ReactivePedal.cpp **** 
  37:ReactivePedal.cpp **** static inline uint32_t ms_to_samps(float ms)
  38:ReactivePedal.cpp **** {
  39:ReactivePedal.cpp ****     return (uint32_t)(ms * 0.001f * sample_rate);
  40:ReactivePedal.cpp **** }
  41:ReactivePedal.cpp **** 
  42:ReactivePedal.cpp **** static inline float tiny_wobble(int a, int b)
  43:ReactivePedal.cpp **** {
  44:ReactivePedal.cpp ****     int   v = (a * 1103515245 + b * 12345) & 0x7fffffff;
  45:ReactivePedal.cpp ****     float f = (float)(v % 1000) / 1000.0f;
  46:ReactivePedal.cpp ****     return (f - 0.5f) * 0.06f;
  47:ReactivePedal.cpp **** }
  48:ReactivePedal.cpp **** 
  49:ReactivePedal.cpp **** // simple noise
  50:ReactivePedal.cpp **** static uint32_t rng_state = 0x12345678u;
  51:ReactivePedal.cpp **** static inline float noise()
  52:ReactivePedal.cpp **** {
  53:ReactivePedal.cpp ****     rng_state = rng_state * 1664525u + 1013904223u;
  54:ReactivePedal.cpp ****     // map to [-1,1]
  55:ReactivePedal.cpp ****     int32_t v = (int32_t)(rng_state >> 9);
  56:ReactivePedal.cpp ****     return (float)(v % 65536 - 32768) / 32768.0f;
  57:ReactivePedal.cpp **** }
  58:ReactivePedal.cpp **** 
  59:ReactivePedal.cpp **** // --------- KS String ----------
  60:ReactivePedal.cpp **** template<int MAX_DELAY>
  61:ReactivePedal.cpp **** struct KSString
  62:ReactivePedal.cpp **** {
  63:ReactivePedal.cpp ****     float    buf[MAX_DELAY]{};
  64:ReactivePedal.cpp ****     int      w = 0;
  65:ReactivePedal.cpp ****     int      delay = 200;
  66:ReactivePedal.cpp ****     float    fb = 0.985f;     // decay
  67:ReactivePedal.cpp ****     float    damp = 0.25f;    // 0..1 (higher = brighter retention)
  68:ReactivePedal.cpp ****     float    last = 0.0f;     // filter state
ARM GAS  /var/folders/6_/psd2b8g56p7696hhrr4ztjs00000gn/T//ccJilNki.s 			page 24


  69:ReactivePedal.cpp ****     float    level = 0.0f;    // excitation strength
  70:ReactivePedal.cpp **** 
  71:ReactivePedal.cpp ****     void SetFreq(float hz)
  72:ReactivePedal.cpp ****     {
  73:ReactivePedal.cpp ****         hz = clampf(hz, 40.0f, sample_rate / 4.0f);
  74:ReactivePedal.cpp ****         int d = (int)(sample_rate / hz);
  75:ReactivePedal.cpp ****         if(d < 2) d = 2;
  76:ReactivePedal.cpp ****         if(d > MAX_DELAY - 1) d = MAX_DELAY - 1;
  77:ReactivePedal.cpp ****         delay = d;
  78:ReactivePedal.cpp ****     }
  79:ReactivePedal.cpp **** 
  80:ReactivePedal.cpp ****     void SetTone(float tone01)
  81:ReactivePedal.cpp ****     {
  82:ReactivePedal.cpp ****         // tone01 = 0 (dark) .. 1 (bright)
  83:ReactivePedal.cpp ****         // damp controls the lowpass in feedback: lower damp => darker
  84:ReactivePedal.cpp ****         damp = 0.10f + 0.70f * tone01;   // 0.10..0.80
  85:ReactivePedal.cpp ****         fb   = 0.975f + 0.020f * tone01; // 0.975..0.995
  86:ReactivePedal.cpp ****     }
  87:ReactivePedal.cpp **** 
  88:ReactivePedal.cpp ****     void Pluck(float strength)
  89:ReactivePedal.cpp ****     {
  90:ReactivePedal.cpp ****         level = clampf(strength, 0.0f, 1.0f);
  91:ReactivePedal.cpp ****         // fill only one period of the delay line with noise (better pitch stability)
  92:ReactivePedal.cpp ****         int r = w - delay;
  93:ReactivePedal.cpp ****         if(r < 0) r += MAX_DELAY;
  94:ReactivePedal.cpp **** 
  95:ReactivePedal.cpp ****         for(int i = 0; i < delay; i++)
  96:ReactivePedal.cpp ****         {
  97:ReactivePedal.cpp ****             int idx = r + i;
  98:ReactivePedal.cpp ****             if(idx >= MAX_DELAY) idx -= MAX_DELAY;
  99:ReactivePedal.cpp ****             buf[idx] = noise() * level;
 100:ReactivePedal.cpp ****         }
 101:ReactivePedal.cpp ****     }
 102:ReactivePedal.cpp **** 
 103:ReactivePedal.cpp ****     float Process()
 104:ReactivePedal.cpp ****     {
 105:ReactivePedal.cpp ****         int r = w - delay;
 106:ReactivePedal.cpp ****         if(r < 0) r += MAX_DELAY;
 107:ReactivePedal.cpp **** 
 108:ReactivePedal.cpp ****         float x = buf[r];
 109:ReactivePedal.cpp **** 
 110:ReactivePedal.cpp ****         // simple 1-pole lowpass in the loop: last = last + damp*(x-last)
 111:ReactivePedal.cpp ****         last = last + damp * (x - last);
 112:ReactivePedal.cpp **** 
 113:ReactivePedal.cpp ****         // write back with feedback decay
 114:ReactivePedal.cpp ****         buf[w] = last * fb;
 115:ReactivePedal.cpp **** 
 116:ReactivePedal.cpp ****         w++;
 117:ReactivePedal.cpp ****         if(w >= MAX_DELAY) w = 0;
 118:ReactivePedal.cpp **** 
 119:ReactivePedal.cpp ****         return x;
 120:ReactivePedal.cpp ****     }
 121:ReactivePedal.cpp **** };
 122:ReactivePedal.cpp **** 
