 189:ReactivePedal.cpp **** 
 190:ReactivePedal.cpp **** // --------- Simple body resonance comb (stereo-ish mono) ----------
 191:ReactivePedal.cpp **** static constexpr int kBodyMax = 4096;
 192:ReactivePedal.cpp **** static float body_buf[kBodyMax]{};
 193:ReactivePedal.cpp **** static int   body_w = 0;
 194:ReactivePedal.cpp **** 
 195:ReactivePedal.cpp **** static inline float BodyProcess(float x, float tone01)
 196:ReactivePedal.cpp **** {
 197:ReactivePedal.cpp ****     // 10–14ms body delay
 198:ReactivePedal.cpp ****     int delay = (int)clampf(520.0f + (1.0f - tone01) * 180.0f, 420.0f, 700.0f);
 199:ReactivePedal.cpp ****     float mix = 0.10f + (1.0f - tone01) * 0.25f; // more body when darker
 200:ReactivePedal.cpp ****     float fb  = 0.70f;
 201:ReactivePedal.cpp **** 
ARM GAS  /var/folders/6_/psd2b8g56p7696hhrr4ztjs00000gn/T//ccJilNki.s 			page 35


 202:ReactivePedal.cpp ****     int r = body_w - delay;
 203:ReactivePedal.cpp ****     if(r < 0) r += kBodyMax;
 204:ReactivePedal.cpp **** 
 205:ReactivePedal.cpp ****     float d = body_buf[r];
 206:ReactivePedal.cpp ****     body_buf[body_w] = x + d * fb;
 207:ReactivePedal.cpp **** 
 208:ReactivePedal.cpp ****     body_w++;
 209:ReactivePedal.cpp ****     if(body_w >= kBodyMax) body_w = 0;
 210:ReactivePedal.cpp **** 
 211:ReactivePedal.cpp ****     return (1.0f - mix) * x + mix * d;
 212:ReactivePedal.cpp **** }
