 245:ReactivePedal.cpp ****     {
 246:ReactivePedal.cpp ****         // clock
 247:ReactivePedal.cpp ****         if(playing)
 248:ReactivePedal.cpp ****         {
 249:ReactivePedal.cpp ****             if(step_counter++ >= samples_per_step)
 250:ReactivePedal.cpp ****             {
 251:ReactivePedal.cpp ****                 step_counter = 0;
 252:ReactivePedal.cpp ****                 const StepEvent e = kPattern[step_idx];
 253:ReactivePedal.cpp ****                 if(e.dir != 0)
 254:ReactivePedal.cpp ****                     ScheduleStrum(e.dir, e.vel);
 255:ReactivePedal.cpp ****                 step_idx = (step_idx + 1) & 7;
 256:ReactivePedal.cpp ****             }
 257:ReactivePedal.cpp ****         }
 258:ReactivePedal.cpp **** 
 259:ReactivePedal.cpp ****         // trigger pending "pluck" events
 260:ReactivePedal.cpp ****         for(int s = 0; s < kNumStrings; s++)
 261:ReactivePedal.cpp ****         {
 262:ReactivePedal.cpp ****             if(sched.pending[s])
 263:ReactivePedal.cpp ****             {
 264:ReactivePedal.cpp ****                 if(sched.delay_samps[s] == 0)
 265:ReactivePedal.cpp ****                 {
 266:ReactivePedal.cpp ****                     // pluck strength per string: a bit stronger on low strings
 267:ReactivePedal.cpp ****                     float low_boost = 1.05f - 0.10f * (float)s;
 268:ReactivePedal.cpp ****                     str[s].Pluck(clampf(sched.vel[s] * low_boost, 0.0f, 1.0f));
 269:ReactivePedal.cpp ****                     sched.pending[s] = false;
 270:ReactivePedal.cpp ****                 }
 271:ReactivePedal.cpp ****                 else
 272:ReactivePedal.cpp ****                 {
