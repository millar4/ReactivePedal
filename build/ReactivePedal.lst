 277:ReactivePedal.cpp **** 
 278:ReactivePedal.cpp ****         // sum strings
 279:ReactivePedal.cpp ****         float x = 0.0f;
 280:ReactivePedal.cpp ****         for(int s = 0; s < kNumStrings; s++)
 281:ReactivePedal.cpp ****             x += str[s].Process();
 282:ReactivePedal.cpp **** 
 283:ReactivePedal.cpp ****         x *= (1.0f / (float)kNumStrings);
 284:ReactivePedal.cpp **** 
 285:ReactivePedal.cpp ****         // body resonance
 286:ReactivePedal.cpp ****         x = BodyProcess(x, tone);
 287:ReactivePedal.cpp **** 
 288:ReactivePedal.cpp ****         // very gentle soft clip
 289:ReactivePedal.cpp ****         x = x / (1.0f + fabsf(x));
 290:ReactivePedal.cpp **** 
 291:ReactivePedal.cpp ****         out[i]     = x * kOutGain;
 292:ReactivePedal.cpp ****         out[i + 1] = x * kOutGain;
 293:ReactivePedal.cpp ****     }
